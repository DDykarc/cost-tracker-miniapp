.page {
  padding: 20rpx 0 160rpx;
  min-height: 100vh;
  background: #F5F6FA;
}

.top-bar {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 30rpx;
}
.top-bar-right {
  display: flex;
  gap: 30rpx;
}
.btn-export {
  font-size: 26rpx;
  color: #00C853;
  padding: 8rpx 20rpx;
  border: 2rpx solid #00C853;
  border-radius: 20rpx;
}
.btn-settings {
  font-size: 26rpx;
  color: #666;
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.card-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.card-icon {
  font-size: 40rpx;
}
.card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.card-unit {
  font-size: 22rpx;
  color: #999;
}
.card-count {
  font-size: 22rpx;
  color: #bbb;
}

/* 最新数据 */
.card-latest {
  margin-bottom: 20rpx;
}
.latest-value-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.latest-value {
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1;
}
.latest-unit {
  font-size: 24rpx;
  color: #999;
}
.latest-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 体重额外信息 */
.weight-info {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 12rpx 0;
}
.bmi-tag, .target-tag, .compare-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.bmi-tag {
  background: #E3F2FD;
  color: #1976D2;
}
.target-tag.under {
  background: #E8F5E9;
  color: #388E3C;
}
.target-tag.over {
  background: #FFEBEE;
  color: #D32F2F;
}
.compare-tag.down {
  background: #E8F5E9;
  color: #388E3C;
}
.compare-tag.up {
  background: #FFEBEE;
  color: #D32F2F;
}

/* 统计数据 */
.card-stats {
  display: flex;
  gap: 0;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}
.stat-value {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 0;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 20rpx;
}
.action-link {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #00C853;
  font-weight: 500;
}

/* 空状态 */
.card-empty {
  padding: 30rpx 0;
  text-align: center;
}
.empty-text {
  font-size: 26rpx;
  color: #ccc;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00C853, #69F0AE);
  color: #fff;
  font-size: 48rpx;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0,200,83,0.4);
  z-index: 100;
}

.loading-wrap {
  text-align: center;
  padding: 60rpx 0;
}
.loading-text {
  font-size: 28rpx;
  color: #999;
}
