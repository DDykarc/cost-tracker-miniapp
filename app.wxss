/**app.wxss**/
page {
  background-color: #F5F6FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #333;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin: 0 20rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 按钮样式 */
.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #00C853, #69F0AE);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 200, 83, 0.3);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 输入框 */
.input-field {
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.input-field:focus {
  border-color: #00C853;
  background: #FFFFFF;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-green {
  background: #E8F5E9;
  color: #2E7D32;
}

.tag-orange {
  background: #FFF3E0;
  color: #E65100;
}

.tag-red {
  background: #FFEBEE;
  color: #C62828;
}
